# phases, modes
compute_what phases
model_parameters 0.2 -3 -1
# Number of discretization points for the iterator that is being split to MPI
global_iterator_steps 16
global_iterator_upper_limit 1
global_iterator_type V
# Number of discretization points for the second iterator
second_iterator_steps 32
second_iterator_upper_limit 0
second_iterator_type U
# Half the number of points in k-space per direction
k_discretization 60
output_folder T0.2/
use_broyden true