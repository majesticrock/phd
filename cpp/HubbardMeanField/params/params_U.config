# phases, modes
compute_what phases
model_parameters 0 -2 -1
# Number of discretization points for the iterator that is being split to MPI
global_iterator_steps 32
global_iterator_upper_limit 0.5
global_iterator_type T
# Number of discretization points for the second iterator
second_iterator_steps 16
second_iterator_upper_limit 1
second_iterator_type V
# Half the number of points in k-space per direction
k_discretization 60
output_folder U-2/
use_broyden true